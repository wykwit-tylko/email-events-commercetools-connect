{
  "name": "event-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "gcp-build": "npm run build",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "dev:subscribe": "tsx src/scripts/dev-subscribe.ts",
    "test": "node scripts/run-tests.cjs",
    "test:integration": "vitest run \"src/**/*.integration.test.ts\" --passWithNoTests",
    "connector:post-deploy": "node dist/src/scripts/post-deploy.js",
    "connector:pre-undeploy": "node dist/src/scripts/pre-undeploy.js"
  },
  "dependencies": {
    "@nats-io/transport-node": "^3.4.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
