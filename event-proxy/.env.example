# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── commercetools Credentials ─────────────────────────────────────────────────
# Required for subscription management and proxy enrichment.
# Provide CTP_REGION to auto-derive API/Auth URLs, or set CTP_API_URL and CTP_AUTH_URL explicitly.
CTP_REGION=europe-west1.gcp
CTP_PROJECT_KEY=your-project-key
CTP_CLIENT_ID=your-client-id
CTP_CLIENT_SECRET=your-client-secret
CTP_SCOPE=manage_subscriptions:your-project-key

# ── Subscription Configuration ────────────────────────────────────────────────
# Key used to identify the commercetools Subscription managed by this Connector.
CT_SUBSCRIPTION_KEY=email-events-proxy

# Comma-separated list of Message resource types the Subscription listens to.
# Default includes order and customer resources.
CT_MESSAGE_RESOURCE_TYPES=approval-flow,approval-rule,associate-role,business-unit,category,customer,customer-email-token,customer-group,customer-password-token,inventory-entry,order,payment,product,product-selection,product-tailoring,quote,quote-request,review,shopping-list,staged-quote,standalone-price,store

# Comma-separated allowlist of Message types to forward. Empty forwards ALL
# types — production deployments should keep the explicit list below.
CT_MESSAGE_TYPES=OrderCreated,CustomerEmailTokenCreated,CustomerPasswordTokenCreated,PaymentTransactionAdded,PaymentTransactionStateChanged

# Platform or CloudEvents
CT_DELIVERY_FORMAT=Platform

# ── Outbound Publisher Configuration ──────────────────────────────────────────
# The proxy forwards Commerce Notifications to one or more outbound publishers.
# A single object is accepted and normalized to a one-element array. To fan out
# to multiple boundaries, provide a JSON array.
#
# cloudflare-queue — POST to the Cloudflare Queue API
# http-webhook — POST a signed JSON body to an HTTP endpoint
#
# Single publisher:
OUTBOUND_PUBLISHER_CONFIG={"type":"cloudflare-queue","accountId":"your-account-id","queueId":"your-queue-id","apiToken":"your-queues-edit-api-token"}
#
# Fan-out to queue + webhook:
# OUTBOUND_PUBLISHER_CONFIG=[{"type":"cloudflare-queue","accountId":"your-account-id","queueId":"your-queue-id","apiToken":"your-queues-edit-api-token"},{"type":"http-webhook","endpointUrl":"https://store.example.com/api/webhooks/events","emailEventSecret":"change-me-webhook-secret"}]
#
# For a single cloudflare-queue publisher, the deploy script can auto-construct
# the JSON from the following variables instead of the full object:
# CF_ACCOUNT_ID=your-account-id
# CF_QUEUE_ID=your-queue-id
# CF_QUEUE_API_TOKEN=your-queues-edit-api-token
#
# Note: When deploying via the deploy script, comma-containing values (including
# this JSON and CT_MESSAGE_TYPES) are automatically base64-encoded with a b64:
# prefix to avoid CLI comma-splitting. The app decodes them transparently.

# ── Proxy Behavior ────────────────────────────────────────────────────────────
# Maximum accepted request body size in bytes
MAX_BODY_BYTES=90000

# Timeout for forwarding a Commerce Notification to the queue
FORWARDING_TIMEOUT_MS=2000

# When true, receive and inspect notifications without forwarding (development only)
DRY_RUN_FORWARDING=true

# ── Development Inspection ────────────────────────────────────────────────────
# Enable in-memory inspection endpoints at /event-proxy/dev/*
DEV_INSPECTION_ENABLED=true

# Maximum number of notifications kept in the development inspection log
DEV_INSPECTION_MAX_MESSAGES=100

# Bearer token required on /event-proxy/dev/* requests. If unset or empty, the
# inspection endpoints respond 404 even when DEV_INSPECTION_ENABLED=true.
DEV_INSPECTION_TOKEN=change-me-inspection-token
